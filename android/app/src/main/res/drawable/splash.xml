<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fundo premium: gradiente suave tema Viva Solar -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="160"
                android:centerColor="#F0F8FC"
                android:endColor="#D6EDF5"
                android:startColor="#EBF3FA"
                android:type="linear" />
        </shape>
    </item>

    <!-- Ícone centralizado — 120dp -->
    <item
        android:width="120dp"
        android:height="120dp"
        android:drawable="@drawable/ic_foreground"
        android:gravity="center" />

</layer-list>
