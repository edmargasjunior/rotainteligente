{
  "appId": "com.edmargasjunior.rotainteligente",
  "appName": "RotaInteligente",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#0f172a"
  },
  "plugins": {
    "Geolocation": {
      "permissions": [
        "location"
      ]
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "launchFadeOutDuration": 500,
      "backgroundColor": "#EBF3FA",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER"
    }
  }
}
